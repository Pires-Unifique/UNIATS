# =====================================================================
# Plataforma de Triagem e Análise de Entrevistas — variáveis de ambiente
# =====================================================================
# Copie este arquivo para `.env` e preencha. NUNCA comite o .env real.
# Para gerar segredos: `openssl rand -base64 48`
# =====================================================================

# --- Ambiente ---
NODE_ENV=development
APP_NAME=uniats-api
APP_PORT=13001
LOG_LEVEL=debug                     # trace|debug|info|warn|error
LOG_PRETTY=true                     # false em produção

# --- Banco de dados (PostgreSQL 16 + pgvector) ---
DATABASE_URL=postgresql://uniats:uniats@localhost:5432/uniats?schema=public&connection_limit=20

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:16379
REDIS_QUEUE_PREFIX=uniats

# --- Autenticação (Microsoft Entra ID / Azure AD) ---
AZURE_AD_TENANT_ID=                 # ex.: 11111111-2222-3333-4444-555555555555
AZURE_AD_CLIENT_ID=                 # app registration no Azure
AZURE_AD_CLIENT_SECRET=             # client secret do app registration
AZURE_AD_AUDIENCE=api://uniats-api
AZURE_AD_ALLOWED_DOMAIN=unifique.com.br
JWT_SECRET=                         # apenas para tokens internos (refresh, webhook signing)
SESSION_SECRET=                     # cookie de sessão do Next.js

# --- Gupy ---
GUPY_API_BASE_URL=https://api.gupy.io/api/v1
GUPY_OS_API_BASE_URL=https://api.gupy.io/os/v1   # API de estrutura organizacional (departamentos/cargos/filiais)
GUPY_API_TOKEN=                     # Bearer token (gerado em Configurações > Integrações)
GUPY_WEBHOOK_SECRET=                # segredo HMAC compartilhado para validar assinatura
GUPY_TIMEOUT_MS=15000
GUPY_RATE_LIMIT_RPS=5               # requisições/segundo (respeitar limites Gupy)
GUPY_RETRY_MAX=4
GUPY_RETRY_BASE_MS=500

# --- IA: Embeddings (Voyage AI) ---
VOYAGE_API_KEY=
VOYAGE_API_BASE_URL=https://api.voyageai.com
VOYAGE_MODEL=voyage-3
VOYAGE_DIMENSIONS=1024
VOYAGE_TIMEOUT_MS=20000
VOYAGE_RETRY_MAX=3
# Rate limit client-side (evita 429). Trial ≈ 3 RPM; aumente conforme o tier pago.
VOYAGE_RATE_LIMIT_RPM=3
VOYAGE_MAX_CONCURRENT=1

# --- Provedor de embeddings: 'voyage' (API) ou 'local' (transformers.js) ---
EMBEDDING_PROVIDER=voyage           # local = grátis, sem rate limit, dados não saem do servidor
EMBEDDING_LOCAL_MODEL=Xenova/multilingual-e5-base   # só p/ local (e5-base=768d, 512 tokens)
# EMBEDDING_DIMENSIONS=768          # sobrescreve a dimensão; deve bater com a coluna pgvector

# --- Camada 3: workers de embedding/matching ---
EMBEDDING_CONCURRENCY=2             # jobs simultâneos de embedding (Voyage)
MATCHING_CONCURRENCY=2              # jobs simultâneos de ranking (Claude)
MATCHING_TOP_K=20                   # default de itens retornados em /ranking

# --- IA: LLM (Anthropic Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT_MS=60000          # timeout HTTP por chamada
ANTHROPIC_RETRY_MAX=3               # retentativas automáticas do SDK

# --- Camada 2: workers de currículo ---
CV_DOWNLOAD_CONCURRENCY=3           # jobs simultâneos para download de CV
CV_PARSE_CONCURRENCY=2              # jobs simultâneos para parse + LLM
CV_MAX_SIZE_BYTES=15728640          # 15 MB — limite duro de tamanho de CV

# --- WhatsApp (WAHA — WhatsApp HTTP API self-hosted) ---
# Rode WAHA via docker: `docker run -p 3000:3000 devlikeapro/waha`
# Após startar, escaneie o QR no dashboard (http://localhost:3000/dashboard).
WAHA_BASE_URL=http://localhost:3000
WAHA_SESSION=default                # 'default' em WAHA Core; nomes livres em WAHA Plus
WAHA_API_KEY=                       # X-Api-Key (defina o env do container)
WAHA_WEBHOOK_SECRET=                # HMAC-SHA256 do payload — configurado via session.config
WAHA_TIMEOUT_MS=20000
WAHA_RETRY_MAX=3
WAHA_TYPING_MS=1500                 # tempo simulado de "digitando..." antes de mandar

# --- E-mail (SendGrid) ---
SENDGRID_API_KEY=                   # SG.xxx (gere em sendgrid.com)
SENDGRID_FROM_EMAIL=triagem@unifique.com.br
SENDGRID_FROM_NAME=Unifique — Recrutamento
SENDGRID_WEBHOOK_PUBLIC_KEY=        # chave pública ECDSA para validar webhooks (Mail Settings → Event Webhook)

# --- Worker de mensageria ---
MENSAGEM_CONCURRENCY=2              # jobs simultâneos de envio (WhatsApp/Email)

# --- Google Calendar ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.uniats.unifique.com.br/auth/google/callback

# --- Bot de Entrevista (MeetStream) ---
MEETSTREAM_API_KEY=                 # token do painel MeetStream
MEETSTREAM_BASE_URL=https://api.meetstream.ai
MEETSTREAM_TIMEOUT_MS=30000
MEETSTREAM_RETRY_MAX=3
MEETSTREAM_WEBHOOK_SECRET=          # HMAC-SHA256 das notificações de bot

# --- Transcrição (AssemblyAI Universal-2) ---
ASSEMBLYAI_API_KEY=                 # api key (sem prefixo Bearer)
ASSEMBLYAI_LANGUAGE_CODE=pt
ASSEMBLYAI_SPEAKER_LABELS=true
ASSEMBLYAI_SENTIMENT_ANALYSIS=true
ASSEMBLYAI_TIMEOUT_MS=30000
ASSEMBLYAI_RETRY_MAX=3
ASSEMBLYAI_WEBHOOK_SECRET=         # valor enviado no header X-Webhook-Secret

# --- Workers Camada 4 (entrevista) ---
BOT_ENTREVISTA_CONCURRENCY=2
AUDIO_PROCESS_CONCURRENCY=1         # áudio pesado, criptografia: cuidado com memória
TRANSCRICAO_CONCURRENCY=1
ANALISE_VOZ_CONCURRENCY=1
AUDIO_MAX_BYTES=209715200           # 200 MB hard cap por entrevista

# --- URL pública desta API (para construir webhook URLs do MeetStream/AssemblyAI) ---
# A API é exposta via proxy reverso (TLS); porta interna = APP_PORT (13001).
PUBLIC_BASE_URL=https://api.uniats.unifique.com.br

# --- Storage de arquivos (currículos/áudios) ---
# Use MinIO local em dev. Em produção, S3 ou Azure Blob.
STORAGE_PROVIDER=minio              # minio | s3 | azure-blob | local
STORAGE_BUCKET=uniats
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=uniats
STORAGE_SECRET_KEY=triagem-secret-change-me
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

# --- Criptografia em repouso (áudios + transcrições) ---
# Chave AES-256 (32 bytes em base64) — `openssl rand -base64 32`
DATA_ENCRYPTION_KEY=

# --- LGPD / retenção (em dias) ---
RETENCAO_AUDIO_DIAS=90
RETENCAO_TRANSCRICAO_DIAS=365
RETENCAO_CV_DIAS=730

# --- Frontend ---
# Origem do front (web) — usada pelo CORS da API. Porta interna do web = 13000.
FRONTEND_ORIGIN=https://uniats.unifique.com.br
NEXT_PUBLIC_API_BASE_URL=https://api.uniats.unifique.com.br
NEXT_PUBLIC_APP_ENV=development

# --- Observabilidade ---
OTEL_EXPORTER_OTLP_ENDPOINT=        # opcional, ex.: http://localhost:4318
SENTRY_DSN=                         # opcional

# --- Rate limit (API pública/webhooks) ---
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
