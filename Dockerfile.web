# =====================================================================
# Web (Next.js) — UniATS  •  build context = raiz do monorepo
# Build: docker build -f Dockerfile.web --target runtime -t uniats-web \
#          --build-arg NEXT_PUBLIC_API_BASE_URL=https://api-uniats.unifique.com.br .
# =====================================================================

FROM node:20-bookworm-slim AS base
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable
WORKDIR /app

# ---- deps ---------------------------------------------------------------------------
FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY apps/web/package.json        apps/web/package.json
COPY packages/shared/package.json packages/shared/package.json
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile

# ---- build --------------------------------------------------------------------------
FROM deps AS build
# NEXT_PUBLIC_* são embutidos no bundle do navegador EM BUILD TIME.
ARG NEXT_PUBLIC_API_BASE_URL=https://api-uniats.unifique.com.br
ARG NEXT_PUBLIC_APP_ENV=production
# Azure AD / agenda Teams (delegado, SPA). Sem CLIENT_ID, o botão de buscar
# horários fica desabilitado (graphEnabled() === false).
ARG NEXT_PUBLIC_AZURE_AD_TENANT_ID=
ARG NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
ARG NEXT_PUBLIC_AZURE_AD_API_SCOPE=
ARG NEXT_PUBLIC_AZURE_AD_SSO=
# Login local obrigatório (admin/admin) quando SSO está desligado.
ARG NEXT_PUBLIC_LOGIN_LOCAL=
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_APP_ENV=$NEXT_PUBLIC_APP_ENV
ENV NEXT_PUBLIC_AZURE_AD_TENANT_ID=$NEXT_PUBLIC_AZURE_AD_TENANT_ID
ENV NEXT_PUBLIC_AZURE_AD_CLIENT_ID=$NEXT_PUBLIC_AZURE_AD_CLIENT_ID
ENV NEXT_PUBLIC_AZURE_AD_API_SCOPE=$NEXT_PUBLIC_AZURE_AD_API_SCOPE
ENV NEXT_PUBLIC_AZURE_AD_SSO=$NEXT_PUBLIC_AZURE_AD_SSO
ENV NEXT_PUBLIC_LOGIN_LOCAL=$NEXT_PUBLIC_LOGIN_LOCAL
ENV NEXT_TELEMETRY_DISABLED=1
COPY . .
# Remove `node-options=--use-system-ca` do .npmrc (válida só p/ dev em Node 22+;
# o Node 20 da imagem rejeita a flag quando o pnpm spawna o node).
RUN sed -i '/^node-options/d' .npmrc 2>/dev/null || true
RUN pnpm --filter @uniats/shared build \
 && pnpm --filter @uniats/web build

# ---- test (typecheck) — alvo usado só no CI -----------------------------------------
# (lint removido: sem config de ESLint commitada; next lint exigiria setup interativo)
FROM build AS test
RUN pnpm --filter @uniats/web typecheck

# ---- runtime ------------------------------------------------------------------------
FROM build AS runtime
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
WORKDIR /app/apps/web
EXPOSE 13000
# -H 0.0.0.0: aceita conexões de outros containers/host (o nginx do host fala aqui).
CMD ["pnpm", "exec", "next", "start", "-p", "13000", "-H", "0.0.0.0"]
