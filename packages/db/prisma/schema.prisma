// =====================================================================
// Plataforma de Triagem e Análise de Entrevistas — Schema Prisma
// =====================================================================
// Convenções:
// - Nomes de tabelas em PORTUGUÊS (snake_case) via @@map.
// - Nomes de modelos no Prisma em PascalCase (boa prática do ORM).
// - Soft delete via coluna `excluido_em` quando aplicável (LGPD).
// - Coluna `criado_em` e `atualizado_em` em todas as tabelas.
// - Coluna `gupy_id` para todas as entidades espelhadas da Gupy (idempotência).
// - pgvector para colunas `vetor` (embeddings).
// =====================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, uuid_ossp(map: "uuid-ossp")]
}

// ---------------------------------------------------------------------
// USUÁRIOS INTERNOS (recrutadores, gestores, admin) — via SSO Azure AD
// ---------------------------------------------------------------------
model Usuario {
  id              String     @id @default(uuid()) @db.Uuid
  azure_oid       String     @unique // Object ID do Azure AD (estável)
  email           String     @unique
  nome            String
  // Legado/exibição. A AUTORIZAÇÃO usa `areas` (abaixo); papel não decide acesso.
  papel           PapelUsuario @default(RECRUTADOR)
  // Áreas de acesso (módulos). Fonte de verdade da autorização. Conjunto, pois
  // uma pessoa pode estar em +1 equipe. Valores: 'admin' | 'recrutamento' |
  // 'admissao' | 'offboarding'. 'admin' = acesso a tudo. Gestor NÃO é uma área:
  // o acesso dele vem da posse da vaga (gestor_id). Atribuição manual por ora;
  // futuramente mapeada de grupos de AD (App Roles → claim `roles`).
  areas           String[]   @default([])
  ativo           Boolean    @default(true)
  ultimo_login_em DateTime?
  criado_em       DateTime   @default(now())
  atualizado_em   DateTime   @updatedAt

  vagas_gestao    Vaga[]               @relation("VagaGestor")
  vagas_recrut   Vaga[]                @relation("VagaRecrutador")
  entrevistas     Entrevista[]
  admissoes       Admissao[]           @relation("AdmissaoResponsavel")
  auditorias      RegistroAuditoria[]
  templates_criados      TemplateMensagem[] @relation("TemplateCriador")
  templates_atualizados  TemplateMensagem[] @relation("TemplateAtualizador")

  @@map("usuarios")
}

enum PapelUsuario {
  ADMIN
  RECRUTADOR
  GESTOR
  VISUALIZADOR

  @@map("papel_usuario")
}

// ---------------------------------------------------------------------
// VAGAS — espelho da vaga publicada na Gupy
// ---------------------------------------------------------------------
model Vaga {
  id                  String     @id @default(uuid()) @db.Uuid
  gupy_id             BigInt     @unique           // id numérico na Gupy
  codigo              String?                       // código interno (jobCode)
  titulo              String
  descricao           String?    @db.Text
  departamento        String?
  unidade             String?
  cidade              String?
  estado              String?
  tipo_contrato       String?
  remoto              Boolean    @default(false)
  status              StatusVaga @default(PUBLICADA)
  data_publicacao     DateTime?
  data_fechamento     DateTime?
  recrutador_id       String?    @db.Uuid
  gestor_id           String?    @db.Uuid
  recrutador          Usuario?   @relation("VagaRecrutador", fields: [recrutador_id], references: [id])
  gestor              Usuario?   @relation("VagaGestor",    fields: [gestor_id],     references: [id])

  // Espelho (lower/trim) de gupy_payload.managerEmail / recruiterEmail. Materializado
  // e indexado para o AUTO-VÍNCULO gestor↔vaga por e-mail (escopo de acesso por papel):
  // no login casamos o e-mail do usuário com gestor_email; no sync casamos no sentido inverso.
  gestor_email        String?
  recrutador_email    String?

  // Requisitos preenchidos pelo líder em campos customizados
  // Estrutura flexível em JSON (validada por Zod no app) + cópia textual
  requisitos_json     Json?
  requisitos_texto    String?    @db.Text          // texto consolidado p/ embedding

  // Sincronização
  gupy_sincronizado_em DateTime?
  gupy_payload        Json?                        // último payload bruto

  criado_em           DateTime   @default(now())
  atualizado_em       DateTime   @updatedAt
  excluido_em         DateTime?

  candidaturas        Candidatura[]
  embeddings          Embedding[]
  perguntas           PerguntaEntrevista[]
  admissoes           Admissao[]

  @@index([status])
  @@index([data_publicacao])
  @@index([gestor_email])
  @@index([recrutador_email])
  @@index([titulo(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("vagas")
}

enum StatusVaga {
  RASCUNHO
  PUBLICADA
  PAUSADA
  ENCERRADA
  CANCELADA

  @@map("status_vaga")
}

// ---------------------------------------------------------------------
// CANDIDATOS — pessoa física (único cross-vaga)
// ---------------------------------------------------------------------
model Candidato {
  id              String   @id @default(uuid()) @db.Uuid
  gupy_id         BigInt   @unique
  email           String?  // pode mudar; chave estável é gupy_id
  telefone        String?
  nome_completo   String
  cpf_hash        String?  @db.Char(64)             // SHA-256 do CPF (não armazenar em claro)
  linkedin_url    String?
  cidade          String?
  estado          String?

  // LGPD
  consentimento_lgpd_em      DateTime?
  consentimento_lgpd_versao  String?
  consentimento_gravacao_em  DateTime?              // gravação/análise de voz

  gupy_payload    Json?
  criado_em       DateTime @default(now())
  atualizado_em   DateTime @updatedAt
  excluido_em     DateTime?

  candidaturas    Candidatura[]
  curriculos      CurriculoProcessado[]
  mensagens       Mensagem[]
  entrevistas     Entrevista[]
  enquetes_horario EnqueteHorario[]
  admissoes       Admissao[]

  @@index([email])
  @@index([nome_completo(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("candidatos")
}

// ---------------------------------------------------------------------
// CANDIDATURAS — aplicação de um candidato a uma vaga (N:N + extras)
// ---------------------------------------------------------------------
model Candidatura {
  id                String              @id @default(uuid()) @db.Uuid
  gupy_id           BigInt              @unique
  vaga_id           String              @db.Uuid
  candidato_id      String              @db.Uuid
  etapa_gupy        String?                                 // nome da etapa atual no funil
  status            StatusCandidatura   @default(EM_ANALISE)
  motivo_desclassif String?
  inscrito_em       DateTime?
  movido_em         DateTime?
  gupy_payload      Json?
  criado_em         DateTime            @default(now())
  atualizado_em     DateTime            @updatedAt

  vaga              Vaga                @relation(fields: [vaga_id], references: [id], onDelete: Cascade)
  candidato         Candidato           @relation(fields: [candidato_id], references: [id], onDelete: Cascade)
  curriculo         CurriculoProcessado?
  scores            Score[]
  entrevistas       Entrevista[]
  mensagens         Mensagem[]
  enquetes_horario  EnqueteHorario[]
  admissao          Admissao?

  @@unique([vaga_id, candidato_id])
  @@index([status])
  @@index([etapa_gupy])
  @@map("candidaturas")
}

enum StatusCandidatura {
  EM_ANALISE
  TRIAGEM_IA
  APROVADO_TRIAGEM
  ENTREVISTA_AGENDADA
  ENTREVISTA_REALIZADA
  APROVADO
  REPROVADO
  CONTRATADO
  DESISTENTE

  @@map("status_candidatura")
}

// ---------------------------------------------------------------------
// CURRÍCULOS PROCESSADOS — texto estruturado extraído do PDF/DOCX
// ---------------------------------------------------------------------
model CurriculoProcessado {
  id                String   @id @default(uuid()) @db.Uuid
  candidatura_id    String   @unique @db.Uuid
  candidato_id      String   @db.Uuid

  arquivo_url       String?                       // URL do PDF original (storage)
  arquivo_sha256    String?  @db.Char(64)
  texto_bruto       String   @db.Text
  texto_normalizado String   @db.Text             // texto usado para embedding

  // Estrutura parseada (LLM-assisted)
  resumo            String?  @db.Text
  experiencias      Json?    // [{empresa, cargo, inicio, fim, descricao, ...}]
  formacoes         Json?    // [{instituicao, curso, nivel, conclusao, ...}]
  competencias      String[] // ["Node.js", "PostgreSQL", ...]
  idiomas           Json?    // [{idioma, nivel}]
  certificacoes     Json?
  anos_experiencia  Float?

  parser_versao     String                        // versionamento do parser
  processado_em     DateTime @default(now())
  atualizado_em     DateTime @updatedAt

  candidatura       Candidatura @relation(fields: [candidatura_id], references: [id], onDelete: Cascade)
  candidato         Candidato   @relation(fields: [candidato_id], references: [id], onDelete: Cascade)
  embeddings        Embedding[]

  @@map("curriculos_processados")
}

// ---------------------------------------------------------------------
// EMBEDDINGS — vetores para vagas e currículos
// ---------------------------------------------------------------------
// Usamos uma tabela única polimórfica: ou vaga_id, ou curriculo_id é preenchido.
model Embedding {
  id              String   @id @default(uuid()) @db.Uuid
  vaga_id         String?  @db.Uuid
  curriculo_id    String?  @db.Uuid

  // Conteúdo vetorizado
  trecho          String   @db.Text                    // texto fonte
  vetor           Unsupported("vector(1024)")          // Voyage-3 → 1024 dims (local e5-base usaria 768)
  modelo          String                               // ex.: "voyage-3"
  modelo_versao   String?
  criado_em       DateTime @default(now())

  vaga            Vaga?                @relation(fields: [vaga_id], references: [id], onDelete: Cascade)
  curriculo       CurriculoProcessado? @relation(fields: [curriculo_id], references: [id], onDelete: Cascade)

  @@index([vaga_id])
  @@index([curriculo_id])
  // Índice HNSW para busca aproximada — criado via migration SQL bruta:
  //   CREATE INDEX embeddings_vetor_idx ON embeddings USING hnsw (vetor vector_cosine_ops);
  @@map("embeddings")
}

// ---------------------------------------------------------------------
// SCORES — avaliação de aderência (CV + entrevista + voz, consolidado)
// ---------------------------------------------------------------------
model Score {
  id                String   @id @default(uuid()) @db.Uuid
  candidatura_id    String   @db.Uuid
  tipo              TipoScore
  valor             Float                            // 0..100
  justificativa     String   @db.Text
  evidencias        Json?                            // citações da fonte (CV/entrevista)
  modelo            String                           // "claude-sonnet-4-6" / "voyage-3"
  prompt_versao     String?
  revisado_por      String?  @db.Uuid                // usuário humano que aprovou
  revisado_em       DateTime?
  criado_em         DateTime @default(now())

  candidatura       Candidatura @relation(fields: [candidatura_id], references: [id], onDelete: Cascade)

  @@index([candidatura_id, tipo])
  @@map("scores")
}

enum TipoScore {
  SIMILARIDADE_VETORIAL     // pgvector
  RANKING_CV                // re-rank do CV pelo LLM
  ENTREVISTA                // qualidade técnica da entrevista
  TOM_DE_VOZ                // sentiment/emocional
  CONSOLIDADO               // score final mostrado ao recrutador

  @@map("tipo_score")
}

// ---------------------------------------------------------------------
// MENSAGENS — convites, follow-ups, validações (WhatsApp / E-mail)
// ---------------------------------------------------------------------
model Mensagem {
  id                String       @id @default(uuid()) @db.Uuid
  candidatura_id    String?      @db.Uuid
  candidato_id      String       @db.Uuid
  canal             CanalMensagem
  direcao           Direcao      @default(SAIDA)
  template_codigo   String?
  assunto           String?
  corpo             String       @db.Text
  destino           String                                // telefone ou e-mail
  provider          String                                // "z-api" | "sendgrid"
  provider_msg_id   String?                               // id retornado pelo provider
  status            StatusMensagem @default(PENDENTE)
  erro              String?       @db.Text
  agendado_para     DateTime?
  enviado_em        DateTime?
  entregue_em       DateTime?
  lido_em           DateTime?
  respondido_em     DateTime?
  criado_em         DateTime     @default(now())
  atualizado_em     DateTime     @updatedAt

  candidatura       Candidatura? @relation(fields: [candidatura_id], references: [id])
  candidato         Candidato    @relation(fields: [candidato_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([candidatura_id])
  @@map("mensagens")
}

enum CanalMensagem {
  WHATSAPP
  EMAIL
  SMS

  @@map("canal_mensagem")
}

// ---------------------------------------------------------------------
// ENQUETE DE HORÁRIOS — propõe N opções ao candidato (enquete WhatsApp)
// e captura o voto dele para o recrutador agendar no horário escolhido.
// ---------------------------------------------------------------------
model EnqueteHorario {
  id                String        @id @default(uuid()) @db.Uuid
  candidatura_id    String        @db.Uuid
  candidato_id      String        @db.Uuid
  canal             CanalMensagem @default(WHATSAPP)
  provider          String        @default("waha")
  provider_msg_id   String?                              // id da mensagem-enquete (liga o voto)
  pergunta          String
  // Opções oferecidas: [{ rotulo, inicio (ISO), fim (ISO) }] — `rotulo` é o texto
  // exato da opção na enquete; usado para casar com o voto recebido.
  opcoes            Json
  status            String        @default("AGUARDANDO") // AGUARDANDO | RESPONDIDA | CANCELADA
  opcao_escolhida   String?                              // rótulo escolhido pelo candidato
  inicio_escolhido  DateTime?
  fim_escolhido     DateTime?
  respondido_em     DateTime?
  // Entrevista criada quando o recrutador confirma o horário escolhido. Único:
  // garante idempotência — reconfirmar a mesma enquete não recria a reunião.
  entrevista_id     String?       @unique @db.Uuid
  criado_em         DateTime      @default(now())
  atualizado_em     DateTime      @updatedAt

  candidatura       Candidatura   @relation(fields: [candidatura_id], references: [id], onDelete: Cascade)
  candidato         Candidato     @relation(fields: [candidato_id], references: [id], onDelete: Cascade)
  entrevista        Entrevista?   @relation(fields: [entrevista_id], references: [id], onDelete: SetNull)

  @@index([provider_msg_id])
  @@index([candidatura_id])
  @@map("enquetes_horario")
}

enum Direcao {
  ENTRADA
  SAIDA

  @@map("direcao_mensagem")
}

enum StatusMensagem {
  PENDENTE
  ENVIADO
  ENTREGUE
  LIDO
  RESPONDIDO
  FALHADO
  CANCELADO

  @@map("status_mensagem")
}

// ---------------------------------------------------------------------
// ENTREVISTAS — sessão agendada/realizada
// ---------------------------------------------------------------------
model Entrevista {
  id                  String   @id @default(uuid()) @db.Uuid
  candidatura_id      String   @db.Uuid
  candidato_id        String   @db.Uuid
  entrevistador_id    String?  @db.Uuid

  agendada_para       DateTime
  duracao_estimada_min Int     @default(30)
  meet_url            String?
  google_event_id     String?
  // Agendamento via Microsoft Graph (app-only). O evento criado na agenda do
  // recrutador já cria a reunião Teams, bloqueia o horário ("busy") e dispara o
  // convite nativo do Outlook ao candidato (attendee).
  graph_event_id      String?                       // id do evento no Outlook (p/ cancelar)
  teams_join_url      String?                       // joinUrl quando provedor = teams
  provedor_video      String?                       // "teams" | "google_meet"
  // Resolvidos na CRIAÇÃO da reunião (Plano B) — o pull do transcript usa o id
  // direto, sem redescobrir por `$filter=JoinWebUrl eq` (match exato e frágil).
  graph_online_meeting_id String?                   // onlineMeetingId no Graph
  graph_organizador_email String?                   // conta sob a qual o transcript existe

  status              StatusEntrevista @default(AGENDADA)
  bot_provider        String?                       // "meetstream"
  bot_session_id      String?                       // id do bot na MeetStream
  bot_status          String?                       // "joined", "recording", "ended"
  iniciada_em         DateTime?
  finalizada_em       DateTime?

  audio_url           String?                       // storage criptografado
  audio_sha256        String?  @db.Char(64)
  audio_expira_em     DateTime?                     // 90 dias por padrão
  parecer_final       String?  @db.Text
  parecer_aprovado_em DateTime?
  parecer_aprovado_por String? @db.Uuid

  // Decisão coletiva do painel (consolidação do scorecard). Definida no momento
  // em que um humano consolida as avaliações (LGPD Art. 20 — revisão humana).
  recomendacao_painel RecomendacaoPainel?

  criado_em           DateTime @default(now())
  atualizado_em       DateTime @updatedAt

  candidatura         Candidatura @relation(fields: [candidatura_id], references: [id], onDelete: Cascade)
  candidato           Candidato   @relation(fields: [candidato_id], references: [id], onDelete: Cascade)
  entrevistador       Usuario?    @relation(fields: [entrevistador_id], references: [id])

  transcricao         Transcricao?
  analise_voz         AnaliseVoz?
  perguntas           PerguntaEntrevista[]
  avaliacoes          AvaliacaoEntrevista[]
  enquete_horario     EnqueteHorario?               // enquete que originou esta entrevista (se houver)

  @@index([status])
  @@index([agendada_para])
  @@map("entrevistas")
}

enum RecomendacaoPainel {
  CONTRATAR
  CONTRATAR_COM_RESSALVAS
  NAO_CONTRATAR
  INCONCLUSIVO

  @@map("recomendacao_painel")
}

enum StatusEntrevista {
  AGENDADA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
  NAO_COMPARECEU

  @@map("status_entrevista")
}

// ---------------------------------------------------------------------
// PERGUNTAS DE ENTREVISTA — geradas pelo Cérebro de IA antes da call
// ---------------------------------------------------------------------
model PerguntaEntrevista {
  id              String   @id @default(uuid()) @db.Uuid
  entrevista_id   String?  @db.Uuid
  vaga_id         String   @db.Uuid

  ordem           Int
  pergunta        String   @db.Text
  objetivo        String?  @db.Text                  // o que valida
  competencia     String?                            // skill relacionada
  dificuldade     String?                            // baixa/media/alta
  resposta_esperada String? @db.Text
  modelo          String                             // "claude-sonnet-4-6"
  prompt_versao   String?
  criado_em       DateTime @default(now())

  entrevista      Entrevista? @relation(fields: [entrevista_id], references: [id], onDelete: Cascade)
  vaga            Vaga        @relation(fields: [vaga_id], references: [id], onDelete: Cascade)
  avaliacoes      AvaliacaoEntrevista[]

  @@index([entrevista_id])
  @@map("perguntas_entrevista")
}

// ---------------------------------------------------------------------
// AVALIAÇÕES DE ENTREVISTA — scorecard estruturado por competência
// ---------------------------------------------------------------------
// Substitui o parecer em texto livre por avaliação por competência, com escala
// e evidência, amarrada às PerguntaEntrevista. Cada avaliador (painel: técnico,
// gestor, DHO) pontua competência a competência; a consolidação produz um
// Score de tipo ENTREVISTA (0..100) e a `recomendacao_painel` da entrevista.
//
// `avaliador_id` espelha o padrão de `Score.revisado_por`: é o id do usuário
// (sem FK rígida enquanto o módulo de auth não está plugado). `avaliador_nome`
// é um snapshot para exibição no painel mesmo sem resolver o usuário.
//
// Linhas com `origem = IA_SUGERIDO` são pré-preenchimentos do Claude a partir da
// transcrição — NUNCA contam para o Score oficial nem para a decisão coletiva;
// servem só de rascunho que o humano confirma (preserva LGPD Art. 20).
model AvaliacaoEntrevista {
  id              String   @id @default(uuid()) @db.Uuid
  entrevista_id   String   @db.Uuid
  avaliador_id    String?  @db.Uuid              // usuarios.id (loose, como Score.revisado_por)
  avaliador_nome  String                          // snapshot p/ exibição no painel
  competencia     String                          // casa com PerguntaEntrevista.competencia
  nota            Int                             // escala 1..5
  peso            Int      @default(1)             // ponderação da competência (1..5)
  evidencia       String?  @db.Text               // citação da fala / justificativa
  origem          OrigemAvaliacao @default(HUMANO)
  pergunta_id     String?  @db.Uuid               // liga a uma PerguntaEntrevista (opcional)
  criado_em       DateTime @default(now())
  atualizado_em   DateTime @updatedAt

  entrevista      Entrevista          @relation(fields: [entrevista_id], references: [id], onDelete: Cascade)
  pergunta        PerguntaEntrevista? @relation(fields: [pergunta_id], references: [id], onDelete: SetNull)

  // Um avaliador dá UMA nota por competência (re-submeter faz upsert).
  // Avaliações da IA usam avaliador_id NULL e não colidem entre si por design
  // (limpamos as antigas antes de regerar).
  @@unique([entrevista_id, avaliador_id, competencia])
  @@index([entrevista_id])
  @@map("avaliacoes_entrevista")
}

enum OrigemAvaliacao {
  HUMANO
  IA_SUGERIDO

  @@map("origem_avaliacao")
}

// ---------------------------------------------------------------------
// TRANSCRIÇÕES — saída do AssemblyAI (com diarização)
// ---------------------------------------------------------------------
model Transcricao {
  id              String   @id @default(uuid()) @db.Uuid
  entrevista_id   String   @unique @db.Uuid

  provider        String                              // "assemblyai"
  provider_id     String?                             // id do job AssemblyAI
  idioma          String   @default("pt-BR")
  texto_completo  String   @db.Text
  segmentos       Json                                // [{inicio_ms, fim_ms, falante, texto, confianca}]
  resumo          String?  @db.Text                   // sumário Claude
  topicos         String[]                            // tópicos extraídos
  expira_em       DateTime?                           // retenção 12 meses
  criado_em       DateTime @default(now())
  atualizado_em   DateTime @updatedAt

  entrevista      Entrevista @relation(fields: [entrevista_id], references: [id], onDelete: Cascade)

  @@map("transcricoes")
}

// ---------------------------------------------------------------------
// ANÁLISES DE VOZ — sentiment/tom de voz
// ---------------------------------------------------------------------
model AnaliseVoz {
  id                  String   @id @default(uuid()) @db.Uuid
  entrevista_id       String   @unique @db.Uuid

  provider            String                              // "assemblyai"
  sentimento_global   String?                             // POSITIVO/NEUTRO/NEGATIVO
  confianca_media     Float?                              // 0..1
  nervosismo_medio    Float?
  entusiasmo_medio    Float?
  hesitacao_count     Int?
  segmentos           Json                                // [{inicio_ms, fim_ms, sentimento, score, ...}]
  observacoes_llm     String?  @db.Text                   // interpretação por Claude
  criado_em           DateTime @default(now())

  entrevista          Entrevista @relation(fields: [entrevista_id], references: [id], onDelete: Cascade)

  @@map("analises_voz")
}

// ---------------------------------------------------------------------
// WEBHOOKS RECEBIDOS — idempotência + replay
// ---------------------------------------------------------------------
model WebhookRecebido {
  id              String   @id @default(uuid()) @db.Uuid
  provider        String                              // "gupy" | "zapi" | "sendgrid" | "meetstream" | "assemblyai"
  evento          String                              // "application.created" etc.
  external_id     String?                             // id do evento no provider (idempotência)
  payload         Json
  assinatura_ok   Boolean  @default(false)
  processado      Boolean  @default(false)
  tentativas      Int      @default(0)
  ultimo_erro     String?  @db.Text
  recebido_em     DateTime @default(now())
  processado_em   DateTime?

  @@unique([provider, external_id])
  @@index([provider, evento, processado])
  @@map("webhooks_recebidos")
}

// ---------------------------------------------------------------------
// AUDITORIA — LGPD / SOX / rastreabilidade
// ---------------------------------------------------------------------
model RegistroAuditoria {
  id              String   @id @default(uuid()) @db.Uuid
  usuario_id      String?  @db.Uuid
  acao            String                              // "criar", "atualizar", "ver_dado_sensivel", ...
  entidade        String                              // "candidatura", "score", ...
  entidade_id     String?  @db.Uuid
  diff            Json?                               // before/after
  ip              String?
  user_agent      String?
  criado_em       DateTime @default(now())

  usuario         Usuario? @relation(fields: [usuario_id], references: [id])

  @@index([entidade, entidade_id])
  @@index([usuario_id])
  @@index([criado_em])
  @@map("registro_auditoria")
}

// ---------------------------------------------------------------------
// TEMPLATES DE MENSAGEM — editáveis pelo recrutador (WhatsApp / E-mail)
// ---------------------------------------------------------------------
// Substitui o catálogo "in-code". As variáveis ({{nome}}) NÃO são colunas:
// são derivadas dos corpos em runtime. `versao` é incrementada a cada edição
// para auditoria (a coluna `template_codigo` em mensagens guarda "codigo@versao").
model TemplateMensagem {
  id              String   @id @default(uuid()) @db.Uuid
  codigo          String   @unique               // slug estável (ex.: "convite_triagem")
  nome            String                          // rótulo humano para a UI
  descricao       String?  @db.Text
  versao          String   @default("v1")
  ativo           Boolean  @default(true)         // soft-disable preserva histórico de envios

  whatsapp_corpo  String?  @db.Text
  email_assunto   String?
  email_texto     String?  @db.Text
  email_html      String?  @db.Text

  criado_por      String?  @db.Uuid
  atualizado_por  String?  @db.Uuid

  criado_em       DateTime @default(now())
  atualizado_em   DateTime @updatedAt

  criador      Usuario? @relation("TemplateCriador",     fields: [criado_por],     references: [id])
  atualizador  Usuario? @relation("TemplateAtualizador", fields: [atualizado_por], references: [id])

  @@index([ativo])
  @@map("templates_mensagem")
}

// =====================================================================
// ADMISSÃO — processo pós-contratação (Departamento Pessoal / DHO)
// =====================================================================
// Agregado que nasce de uma Candidatura com status CONTRATADO. Cobre
// coleta de documentos, exame admissional (ASO), assinatura e envio ao
// eSocial/folha. Dados aqui são SENSÍVEIS (CPF, dependentes, saúde do
// ASO, salário) — acesso deve ser restrito ao time de admissão (a camada
// de autorização por grupo de AD será plugada depois).
// ---------------------------------------------------------------------

model Admissao {
  id                  String   @id @default(uuid()) @db.Uuid
  candidatura_id      String   @unique @db.Uuid
  candidato_id        String   @db.Uuid
  vaga_id             String   @db.Uuid
  responsavel_id      String?  @db.Uuid              // usuário do DHO/RH

  status              StatusAdmissao @default(AGUARDANDO_ACEITE)

  // Dados da contratação
  cargo               String?
  salario             Decimal? @db.Decimal(12, 2)
  tipo_contratacao    String?                        // CLT | PJ | ESTAGIO | APRENDIZ
  jornada             String?
  data_admissao       DateTime?                      // início previsto
  data_aceite         DateTime?
  data_conclusao      DateTime?
  motivo_cancelamento String?

  // Integração folha / eSocial
  esocial_recibo      String?                        // recibo do evento S-2200
  esocial_status      String?
  matricula           String?                        // matrícula no ERP de RH

  observacoes         String?  @db.Text
  criado_em           DateTime @default(now())
  atualizado_em       DateTime @updatedAt
  excluido_em         DateTime?

  candidatura         Candidatura @relation(fields: [candidatura_id], references: [id], onDelete: Cascade)
  candidato           Candidato   @relation(fields: [candidato_id], references: [id], onDelete: Cascade)
  vaga                Vaga        @relation(fields: [vaga_id], references: [id])
  responsavel         Usuario?    @relation("AdmissaoResponsavel", fields: [responsavel_id], references: [id])

  documentos          DocumentoAdmissional[]
  exame               ExameAdmissional?
  eventos             EventoAdmissao[]

  @@index([status])
  @@map("admissoes")
}

enum StatusAdmissao {
  AGUARDANDO_ACEITE
  PROPOSTA_ACEITA
  COLETA_DOCUMENTOS
  DOCUMENTOS_EM_ANALISE
  EXAME_MEDICO
  ASSINATURA_CONTRATO
  ENVIO_ESOCIAL
  INTEGRACAO
  CONCLUIDA
  CANCELADA

  @@map("status_admissao")
}

// ---------------------------------------------------------------------
// DOCUMENTOS ADMISSIONAIS — checklist por admissão (arquivo no storage)
// ---------------------------------------------------------------------
model DocumentoAdmissional {
  id              String   @id @default(uuid()) @db.Uuid
  admissao_id     String   @db.Uuid
  tipo            TipoDocumentoAdmissional
  status          StatusDocumentoAdmissional @default(PENDENTE)
  obrigatorio     Boolean  @default(true)

  arquivo_url     String?                            // storage (MinIO/S3)
  arquivo_sha256  String?  @db.Char(64)
  nome_arquivo    String?
  validade        DateTime?                          // p/ docs com vencimento
  motivo_recusa   String?
  enviado_em      DateTime?
  analisado_por   String?  @db.Uuid
  analisado_em    DateTime?

  criado_em       DateTime @default(now())
  atualizado_em   DateTime @updatedAt

  admissao        Admissao @relation(fields: [admissao_id], references: [id], onDelete: Cascade)

  @@unique([admissao_id, tipo])
  @@index([admissao_id, status])
  @@map("documentos_admissionais")
}

enum TipoDocumentoAdmissional {
  RG
  CPF
  CTPS
  TITULO_ELEITOR
  PIS_NIS
  COMPROVANTE_RESIDENCIA
  COMPROVANTE_ESCOLARIDADE
  CERTIDAO_NASCIMENTO_CASAMENTO
  RESERVISTA
  DADOS_BANCARIOS
  FOTO_3X4
  DEPENDENTES
  OUTRO

  @@map("tipo_documento_admissional")
}

enum StatusDocumentoAdmissional {
  PENDENTE
  ENVIADO
  EM_ANALISE
  APROVADO
  REPROVADO

  @@map("status_documento_admissional")
}

// ---------------------------------------------------------------------
// EXAME ADMISSIONAL (ASO) — 1:1 com a admissão
// ---------------------------------------------------------------------
model ExameAdmissional {
  id            String   @id @default(uuid()) @db.Uuid
  admissao_id   String   @unique @db.Uuid
  clinica       String?
  agendado_para DateTime?
  realizado_em  DateTime?
  resultado     ResultadoExameAdmissional @default(PENDENTE)
  restricoes    String?  @db.Text
  aso_url       String?                            // PDF do ASO no storage
  aso_sha256    String?  @db.Char(64)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  admissao      Admissao @relation(fields: [admissao_id], references: [id], onDelete: Cascade)

  @@map("exames_admissionais")
}

enum ResultadoExameAdmissional {
  PENDENTE
  APTO
  APTO_COM_RESTRICOES
  INAPTO

  @@map("resultado_exame_admissional")
}

// ---------------------------------------------------------------------
// EVENTOS DE ADMISSÃO — timeline das transições de etapa
// ---------------------------------------------------------------------
model EventoAdmissao {
  id           String   @id @default(uuid()) @db.Uuid
  admissao_id  String   @db.Uuid
  de_status    StatusAdmissao?
  para_status  StatusAdmissao
  autor_id     String?  @db.Uuid
  autor_nome   String?
  observacao   String?  @db.Text
  criado_em    DateTime @default(now())

  admissao     Admissao @relation(fields: [admissao_id], references: [id], onDelete: Cascade)

  @@index([admissao_id])
  @@map("eventos_admissao")
}
