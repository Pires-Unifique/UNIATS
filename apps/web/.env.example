# Apps/web — variáveis públicas (prefixadas NEXT_PUBLIC_, vão para o bundle)

# URL base da API NestJS (em dev: localhost:3001)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Azure AD — se vazio, frontend roda em "modo dev" sem login real.
NEXT_PUBLIC_AZURE_AD_TENANT_ID=
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
# Escopo que o token precisa cobrir para chamar a API (ex.: api://triagem-api/access)
NEXT_PUBLIC_AZURE_AD_API_SCOPE=
