{
  "name": "uniats-playwright-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Bot de transcrição (fallback) — entra na reunião do Teams pelo navegador e captura as legendas ao vivo. Self-hosted, roda na rede interna.",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bullmq": "^5.13.2",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "playwright": "1.55.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "pino-pretty": "^11.2.2",
    "typescript": "^5.5.4"
  }
}
