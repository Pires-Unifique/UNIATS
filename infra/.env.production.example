# =====================================================================
# PRODUÇÃO — copie para infra/.env.production e preencha os segredos.
#   cp infra/.env.production.example infra/.env.production
# NUNCA comite o .env.production real.
#
# Este arquivo é usado de DUAS formas no deploy:
#   1) interpolação do compose  -> docker compose --env-file infra/.env.production ...
#   2) montado em /app/.env na API (bootstrap-env.ts carrega com override:true)
#
# As demais variáveis (Gupy, Voyage, Anthropic, WAHA, SendGrid, AssemblyAI,
# MeetStream, Google, criptografia...) seguem o catálogo completo em /.env.example
# — copie de lá as que usar.
# =====================================================================

# --- Ambiente ---
NODE_ENV=production
APP_NAME=uniats-api
APP_PORT=13001
LOG_LEVEL=info
LOG_PRETTY=false

# --- Postgres ---------------------------------------------------------
# POSTGRES_PASSWORD é lido pelo serviço postgres E deve casar com a senha
# embutida na DATABASE_URL abaixo. Host = nome do serviço na rede do compose.
POSTGRES_PASSWORD=CHANGE_ME_senha_forte
DATABASE_URL=postgresql://uniats:CHANGE_ME_senha_forte@postgres:5432/uniats?schema=public&connection_limit=20

# --- Redis ------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_QUEUE_PREFIX=uniats

# --- Storage (MinIO no compose) --------------------------------------
STORAGE_PROVIDER=minio
STORAGE_BUCKET=uniats
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=uniats
STORAGE_SECRET_KEY=CHANGE_ME_minio_secret
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

# --- URLs públicas ----------------------------------------------------
FRONTEND_ORIGIN=https://uniats.unifique.com.br
PUBLIC_BASE_URL=https://api-uniats.unifique.com.br
# Embutida no bundle do navegador EM BUILD TIME (build-arg do web):
NEXT_PUBLIC_API_BASE_URL=https://api-uniats.unifique.com.br
NEXT_PUBLIC_APP_ENV=production

# --- Front: Azure AD / agenda Teams (EMBUTIDAS NO BUILD do web) -------
# App registration tipo SPA (fluxo delegado/popup). Sem CLIENT_ID o botão
# "Buscar horários da agenda" fica desabilitado (graphEnabled() === false).
# Permissões delegadas no Graph: User.Read + Calendars.Read (admin consent).
# Redirect URI (SPA) = a URL pública do front (FRONTEND_ORIGIN), sem barra final.
NEXT_PUBLIC_AZURE_AD_TENANT_ID=
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
# true = exige login SSO no app inteiro. Para SÓ a agenda, deixe vazio.
NEXT_PUBLIC_AZURE_AD_SSO=
# Só se o token for usado para autenticar na API (ex.: api://uniats-api/access).
NEXT_PUBLIC_AZURE_AD_API_SCOPE=

# --- Auth / segredos (gere com: openssl rand -base64 48) --------------
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_AUDIENCE=api://uniats-api
AZURE_AD_ALLOWED_DOMAIN=unifique.com.br
JWT_SECRET=
SESSION_SECRET=

# --- Provedores de IA (preencha conforme uso) -------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
VOYAGE_API_KEY=
EMBEDDING_PROVIDER=voyage

# --- (copie do /.env.example as demais que precisar) ------------------
